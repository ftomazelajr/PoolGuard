<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/surface">

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Nome da piscina"
        android:textColor="@color/textPrimary"
        android:textColorHint="@color/textSecondary"
        android:padding="16dp"
        android:background="@drawable/edit_bg" />

    <EditText
        android:id="@+id/etClient"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Nome do cliente"
        android:textColor="@color/textPrimary"
        android:textColorHint="@color/textSecondary"
        android:padding="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/edit_bg" />

    <EditText
        android:id="@+id/etPhone"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Telefone"
        android:inputType="phone"
        android:textColor="@color/textPrimary"
        android:textColorHint="@color/textSecondary"
        android:padding="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/edit_bg" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dias da semana"
        android:textColor="@color/accent"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <CheckBox android:id="@+id/cbSeg" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SEG" android:textColor="@color/textPrimary" />
        <CheckBox android:id="@+id/cbTer" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TER" android:textColor="@color/textPrimary" />
        <CheckBox android:id="@+id/cbQua" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="QUA" android:textColor="@color/textPrimary" />
        <CheckBox android:id="@+id/cbQui" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="QUI" android:textColor="@color/textPrimary" />
        <CheckBox android:id="@+id/cbSex" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SEX" android:textColor="@color/textPrimary" />

    </LinearLayout>

</LinearLayout>
